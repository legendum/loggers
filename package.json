{
  "name": "loggers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "loggers": "src/cli/main.ts"
  },
  "scripts": {
    "build:web": "bun build src/web/entry.tsx --outdir=public/dist --target=browser --entry-naming=[name]-[hash].js",
    "build": "rm -rf public/dist && bun run build:web && bun run scripts/build-sw.ts",
    "start": "bun run build && bun run src/api/server.ts",
    "dev": "bun run build && bun --hot src/api/server.ts",
    "tsc": "tsc -p tsconfig.typecheck.json",
    "test": "bun test ./tests",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "smoke": "bun run lint && bun run test && bun run tsc && bun run build",
    "loggers": "bun run src/cli/main.ts",
    "pues": "bun run scripts/pues.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.2",
    "workbox-build": "^7.4.0"
  }
}
